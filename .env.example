# MongoDB Connection
MONGODB_URI=your_mongodb_connection_string_here

# JWT — BẮT BUỘC ở production (nếu thiếu, app sẽ báo lỗi thay vì dùng secret mặc định)
JWT_SECRET=doi_thanh_chuoi_ngau_nhien_dai

# URL gốc (dùng cho email xác thực / đặt lại mật khẩu, OAuth callback)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (không bắt buộc)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend — gửi email (quên mật khẩu, xác thực email). Lấy API key tại resend.com
RESEND_API_KEY=
EMAIL_FROM=Bongmeow <onboarding@resend.dev>

# Cloudinary — upload ảnh bìa / avatar. Lấy thông tin tại cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Other configs
NODE_ENV=development
